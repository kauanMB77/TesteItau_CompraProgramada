@model TesteItau_WebMvc.Models.CarteiraViewModel

<h2>Carteira Master</h2>

@if (!Model.Custodias.Any())
{
    <p>Nenhuma custódia encontrada.</p>
}
else
{
    var totalInvestido = Model.Custodias
        .Sum(c => c.Quantidade * c.PrecoMedio);

    <h4>Total Investido: <strong>@totalInvestido.ToString("C")</strong></h4>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Ticker</th>
                <th>Quantidade</th>
                <th>Preço Médio</th>
                <th>Valor Total</th>
                <th>% na Carteira</th>
                <th>Última Atualização</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Custodias)
            {
                var valorTotalAcao = item.Quantidade * item.PrecoMedio;
                var percentual = totalInvestido > 0 ? (valorTotalAcao / totalInvestido) * 100 : 0;

                <tr>
                    <td>@item.Ticker</td>
                    <td>@item.Quantidade</td>
                    <td>@item.PrecoMedio.ToString("C")</td>
                    <td>@valorTotalAcao.ToString("C")</td>
                    <td>@percentual.ToString("N2")%</td>
                    <td>@item.DataUltimaAtualizacao.ToString("dd/MM/yyyy HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}