@model CadastroViewModel

@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Cadastro";
}

<div class="login-container">
    <h2>Cadastro</h2>

    @if (ViewBag.Erro != null)
    {
        <div class="error-message">
            @ViewBag.Erro
        </div>
    }

    @if (ViewBag.Sucesso != null)
    {
        <div class="success-message">
            @ViewBag.Sucesso
        </div>
    }

    <form asp-action="Cadastro" method="post">
        <div class="form-group">
            <label>Nome</label>
            <input asp-for="Nome" />
        </div>

        <div class="form-group">
            <label>CPF</label>
            <input asp-for="Cpf" />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input asp-for="Email" />
        </div>

        <div class="form-group">
            <label>Senha</label>
            <input asp-for="Senha" />
        </div>

        <div class="form-group">
            <label>Valor Mensal</label>
            <input asp-for="ValorMensal" type="number" step="0.01" />
        </div>

        <button type="submit" class="btn-login">Cadastrar</button>
    </form>

    <div style="margin-top: 15px;">
        <a asp-action="Login">Já possui conta? Faça login</a>
    </div>
</div>